{
  "name": "capacity-heatmap-modeler",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Config-driven heatmap modeler for time-series capacity — individuals, teams, and businesses.",
  "scripts": {
    "sync:learn": "node scripts/sync-learn.mjs",
    "predev": "npm run sync:learn",
    "dev": "vite",
    "prebuild": "npm run sync:learn",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
